{
  "name": "redmine-connector",
  "displayName": "Redmine Connector",
  "description": "Connect your company's Redmine to VS Code, Cursor, Windsurf — manage issues and push to AI chat",
  "publisher": "hoangthiep",
  "version": "1.5.1",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "SCM Providers",
    "Testing",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "icon": "resources/redmine.png",
  "license": "MIT",
  "readme": "README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/hoangthiep08/redmine-connector"
  },
  "contributes": {
    "configuration": {
      "title": "Redmine Connector",
      "properties": {
        "redmine.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Redmine server URL (e.g. https://redmine.company.com)"
        },
        "redmine.apiKey": {
          "type": "string",
          "default": "",
          "description": "Your Redmine API key (find it in My Account → API access key)"
        },
        "redmine.defaultProject": {
          "type": "string",
          "default": "",
          "description": "Default project identifier to show issues for"
        },
        "redmine.showOnlyAssignedToMe": {
          "type": "boolean",
          "default": false,
          "description": "Only show issues assigned to me by default"
        },
        "redmine.defaultStatusMode": {
          "type": "string",
          "default": "open",
          "enum": [
            "open",
            "closed",
            "*",
            "custom"
          ],
          "description": "Default status filter mode"
        },
        "redmine.defaultStatusIds": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Specific status IDs to show when defaultStatusMode is custom"
        },
        "redmine.defaultAssigneeMode": {
          "type": "string",
          "default": "all",
          "enum": [
            "all",
            "me",
            "custom"
          ],
          "description": "Default assignee filter: all / me / custom user"
        },
        "redmine.defaultAssigneeId": {
          "type": "string",
          "default": "",
          "description": "User ID to filter by when defaultAssigneeMode is custom"
        },
        "redmine.defaultAssigneeName": {
          "type": "string",
          "default": "",
          "description": "Display name for the custom default assignee (auto-filled when saving settings)"
        },
        "redmine.defaultProjectName": {
          "type": "string",
          "default": "",
          "description": "Display name for the default project (auto-filled when saving settings)"
        },
        "redmine.defaultTrackerId": {
          "type": "string",
          "default": "",
          "description": "Default tracker ID to filter issues (e.g. Bug, Task)"
        },
        "redmine.defaultTrackerName": {
          "type": "string",
          "default": "",
          "description": "Display name for the default tracker (auto-filled when saving settings)"
        },
        "redmine.feedbackWebhookUrl": {
          "type": "string",
          "default": "",
          "description": "n8n webhook URL to receive feedback submissions"
        },
        "redmine.issueDetection.include": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["NG", "Fail"],
          "description": "Status keywords (case-insensitive substring match). A test case row whose Status QC contains any of these shows the 'Create Issue' button."
        },
        "redmine.issueDetection.exclude": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Status keywords that VETO Include. A row matching Exclude never shows 'Create Issue', even if it also matches Include. Example: 'test NG'."
        },
        "redmine.textFormat": {
          "type": "string",
          "default": "textile",
          "enum": [
            "textile",
            "markdown",
            "plain"
          ],
          "enumDescriptions": [
            "Redmine Textile (default)",
            "Markdown",
            "Plain text"
          ],
          "description": "Text format used in your Redmine instance for descriptions and comments"
        },
        "redmine.testCaseTemplate": {
          "type": "object",
          "default": {},
          "description": "Template mapping for Test Case → Issue (internal use, set via Test Case Template builder)"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "redmine",
          "title": "Redmine",
          "icon": "resources/redmine-mono.svg"
        }
      ]
    },
    "views": {
      "redmine": [
        {
          "id": "redmine.issueList",
          "name": "Issues",
          "icon": "resources/redmine.svg"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "redmine",
        "name": "redmine",
        "description": "Query and manage Redmine issues directly in AI chat",
        "isSticky": false
      }
    ],
    "commands": [
      {
        "command": "redmine.refresh",
        "title": "Refresh Issues",
        "icon": "$(refresh)",
        "category": "Redmine"
      },
      {
        "command": "redmine.openIssueList",
        "title": "Open Issue List (Redmine-style)",
        "icon": "$(list-flat)",
        "category": "Redmine"
      },
      {
        "command": "redmine.openIssue",
        "title": "Open Issue Detail",
        "category": "Redmine"
      },
      {
        "command": "redmine.pushToChat",
        "title": "Push Issue to AI Chat",
        "icon": "$(comment-discussion)",
        "category": "Redmine"
      },
      {
        "command": "redmine.copyIssueMarkdown",
        "title": "Copy Issue as Markdown",
        "icon": "$(copy)",
        "category": "Redmine"
      },
      {
        "command": "redmine.updateStatus",
        "title": "Update Status",
        "category": "Redmine"
      },
      {
        "command": "redmine.assignIssue",
        "title": "Assign Issue",
        "category": "Redmine"
      },
      {
        "command": "redmine.addComment",
        "title": "Add Comment",
        "category": "Redmine"
      },
      {
        "command": "redmine.createIssue",
        "title": "Create New Issue",
        "icon": "$(add)",
        "category": "Redmine"
      },
      {
        "command": "redmine.filter",
        "title": "Filter Issues",
        "icon": "$(filter)",
        "category": "Redmine"
      },
      {
        "command": "redmine.clearFilters",
        "title": "Clear Filters",
        "icon": "$(filter-filled)",
        "category": "Redmine"
      },
      {
        "command": "redmine.filterByProject",
        "title": "Filter by Project",
        "category": "Redmine"
      },
      {
        "command": "redmine.filterByStatus",
        "title": "Filter by Status",
        "category": "Redmine"
      },
      {
        "command": "redmine.search",
        "title": "Search Issues",
        "icon": "$(search)",
        "category": "Redmine"
      },
      {
        "command": "redmine.groupBy",
        "title": "Group By",
        "icon": "$(list-tree)",
        "category": "Redmine"
      },
      {
        "command": "redmine.feedback",
        "title": "Send Feedback",
        "icon": "$(feedback)",
        "category": "Redmine"
      },
      {
        "command": "redmine.loadMore",
        "title": "Load More Issues",
        "category": "Redmine"
      },
      {
        "command": "redmine.configure",
        "title": "Configure Redmine Connection",
        "icon": "$(settings-gear)",
        "category": "Redmine"
      },
      {
        "command": "redmine.openTestCase",
        "title": "Redmine: View Test Case",
        "icon": "$(list-ordered)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "redmine.openTestCase",
          "when": "resourceExtname == .md",
          "group": "1_modification"
        }
      ],
      "editor/context": [
        {
          "command": "redmine.openTestCase",
          "when": "resourceExtname == .md",
          "group": "1_modification"
        }
      ],
      "view/title": [
        {
          "command": "redmine.refresh",
          "when": "view == redmine.issueList",
          "group": "navigation@1"
        },
        {
          "command": "redmine.openIssueList",
          "when": "view == redmine.issueList",
          "group": "navigation@1"
        },
        {
          "command": "redmine.search",
          "when": "view == redmine.issueList",
          "group": "navigation@2"
        },
        {
          "command": "redmine.filter",
          "when": "view == redmine.issueList",
          "group": "navigation@3"
        },
        {
          "command": "redmine.createIssue",
          "when": "view == redmine.issueList",
          "group": "navigation@4"
        },
        {
          "command": "redmine.configure",
          "when": "view == redmine.issueList",
          "group": "navigation@5"
        },
        {
          "command": "redmine.feedback",
          "when": "view == redmine.issueList && redmine.isConfigured",
          "group": "navigation@6"
        }
      ],
      "view/item/context": [
        {
          "command": "redmine.openIssue",
          "when": "view == redmine.issueList && viewItem == issue",
          "group": "inline@1"
        },
        {
          "command": "redmine.pushToChat",
          "when": "view == redmine.issueList && viewItem == issue",
          "group": "inline@2"
        },
        {
          "command": "redmine.updateStatus",
          "when": "view == redmine.issueList && viewItem == issue",
          "group": "redmine@1"
        },
        {
          "command": "redmine.assignIssue",
          "when": "view == redmine.issueList && viewItem == issue",
          "group": "redmine@2"
        },
        {
          "command": "redmine.addComment",
          "when": "view == redmine.issueList && viewItem == issue",
          "group": "redmine@3"
        },
        {
          "command": "redmine.copyIssueMarkdown",
          "when": "view == redmine.issueList && viewItem == issue",
          "group": "redmine@4"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "check:webview": "node scripts/check-webview-scripts.js src/settings-webview.ts src/create-issue-webview.ts src/testcase-webview.ts src/issue-list-webview.ts",
    "build": "npm run check:webview && tsc -p ./tsconfig.json",
    "watch": "tsc -watch -p ./tsconfig.json",
    "package": "npm run check:webview && vsce package"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "marked": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "sharp": "^0.34.5",
    "typescript": "^5.3.0"
  }
}